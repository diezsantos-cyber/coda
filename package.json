{
  "name": "coda",
  "version": "1.0.0",
  "description": "CODA - Collaborative Organizational Decision Assistant",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:dashboard": "npm run dev -w packages/dashboard",
    "build": "npm run build --workspaces --if-present",
    "build:backend": "npm run build -w packages/backend",
    "build:dashboard": "npm run build -w packages/dashboard",
    "lint": "npm run lint --workspaces --if-present",
    "lint:backend": "npm run lint -w packages/backend",
    "lint:dashboard": "npm run lint -w packages/dashboard",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:backend": "npm run typecheck -w packages/backend",
    "typecheck:dashboard": "npm run typecheck -w packages/dashboard",
    "test": "npm run test --workspaces --if-present",
    "test:backend": "npm run test -w packages/backend",
    "test:dashboard": "npm run test -w packages/dashboard",
    "db:migrate": "npm run db:migrate -w packages/backend",
    "db:generate": "npm run db:generate -w packages/backend",
    "db:seed": "npm run db:seed -w packages/backend",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist packages/dashboard/.next"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
