{
  "name": "coda",
  "version": "1.0.0",
  "description": "CODA - Collaborative Organizational Decision Assistant",
  "private": true,
  "workspaces": [
    "backend",
    "dashboard"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:backend": "npm run dev -w backend",
    "dev:dashboard": "npm run dev -w dashboard",
    "build": "npm run build --workspaces --if-present",
    "build:backend": "npm run build -w backend",
    "build:dashboard": "npm run build -w dashboard",
    "lint": "npm run lint --workspaces --if-present",
    "lint:backend": "npm run lint -w backend",
    "lint:dashboard": "npm run lint -w dashboard",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:backend": "npm run typecheck -w backend",
    "typecheck:dashboard": "npm run typecheck -w dashboard",
    "test": "npm run test --workspaces --if-present",
    "test:backend": "npm run test -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:generate": "npm run db:generate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "clean": "rm -rf node_modules backend/node_modules backend/dist dashboard/node_modules dashboard/.next"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
